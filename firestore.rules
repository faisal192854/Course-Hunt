rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: courses
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required)
    //   - price: string (required)
    //   - originalPrice: string
    //   - rating: number
    //   - reviews: number
    //   - image: string (required)
    //   - category: string (required)
    //   - additionalChoices: string
    //   - sourceUrl: string
    //   - about: string
    //   - objectives: list
    //   - gallery: list
    //   - fileImages: list
    //   - createdAt: timestamp
    //   - updatedAt: timestamp
    //
    // Collection: reviews
    // Document ID: auto-generated
    // Fields:
    //   - course_id: string (required)
    //   - user_name: string (required)
    //   - rating: number (required)
    //   - comment: string (required)
    //   - image_url: string
    //   - created_at: timestamp
    //
    // Collection: settings
    // Document ID: 'app'
    // Fields:
    //   - announcement: string
    //   - categories: list
    //   - coupons: list of maps
    //
    // Collection: clicks
    // Document ID: auto-generated
    // Fields:
    //   - courseId: string
    //   - timestamp: timestamp
    //   - country: string
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - email: string
    //   - role: string ('admin', 'user')
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ( (request.auth.token.email == "official.faisaln8n@gmail.com" && request.auth.token.email_verified == true) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidCourse(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.price is string && data.price.size() > 0 &&
             data.image is string && data.image.size() > 0 &&
             data.category is string && data.category.size() > 0 &&
             (!('reviews' in data) || data.reviews is number) &&
             (!('rating' in data) || data.rating is number);
    }

    function isValidReview(data) {
      return data.course_id is string &&
             data.user_name is string && data.user_name.size() > 0 && data.user_name.size() < 100 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() > 0 && data.comment.size() < 2000;
    }

    function isValidSettings(data) {
      return (!('announcement' in data) || data.announcement is string) &&
             (!('categories' in data) || data.categories is list);
    }

    function isValidClick(data) {
      return data.courseId is string &&
             (!('timestamp' in data) || data.timestamp is timestamp) &&
             (!('country' in data) || data.country is string);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /courses/{courseId} {
      allow read: if true; // Publicly readable for the marketplace
      allow write: if isAdmin() && isValidCourse(request.resource.data);
    }

    match /reviews/{reviewId} {
      allow read: if true; // Publicly readable
      allow create: if isAuthenticated() && isValidReview(request.resource.data); // Require auth to review
      allow update, delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true; // Publicly readable for announcements/categories
      allow write: if isAdmin() && isValidSettings(request.resource.data);
    }

    match /clicks/{clickId} {
      allow read: if isAdmin();
      allow create: if true; // Anyone can record a click
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId && request.resource.data.role == 'user';
      allow update: if isAdmin(); // Only admin can change roles
    }
  }
}
